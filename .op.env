# 1Password secret references for fetching the Instapaper reading list.
#
# These are op:// REFERENCES, not secrets — they only point at items in your
# 1Password vault. 1Password recommends committing reference files like this.
# DO NOT put literal secret values here.
#
# Used locally (npm run reading:fetch:op) and by CI (reading-refresh.yml).
#
# consumer_key / consumer_secret already exist in the item.
# oauth_token / oauth_token_secret must be added to the same item AFTER running
# the one-time auth step (npm run instapaper:auth:op).

INSTAPAPER_CONSUMER_KEY=op://Development/Instapaper_popyson_reading_list/consumer_key
INSTAPAPER_CONSUMER_SECRET=op://Development/Instapaper_popyson_reading_list/consumer_secret
INSTAPAPER_OAUTH_TOKEN=op://Development/Instapaper_popyson_reading_list/oauth_token
INSTAPAPER_OAUTH_TOKEN_SECRET=op://Development/Instapaper_popyson_reading_list/oauth_token_secret
