# 1Password secret references for the one-time Instapaper access-token exchange.
#
# Copy this file to .op.env.auth and replace the placeholder references with
# your local 1Password vault, item, and field paths. Do not put literal secret
# values in .op.env.auth.

INSTAPAPER_CONSUMER_KEY=op://VAULT/ITEM/consumer_key
INSTAPAPER_CONSUMER_SECRET=op://VAULT/ITEM/consumer_secret
INSTAPAPER_USERNAME=op://VAULT/ITEM/instapaper_email
INSTAPAPER_PASSWORD=op://VAULT/ITEM/instapaper_password
