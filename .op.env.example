# 1Password secret references for fetching the Instapaper reading list.
#
# Copy this file to .op.env and replace the placeholder references with your
# local 1Password vault, item, and field paths. Do not put literal secret values
# in .op.env.

INSTAPAPER_CONSUMER_KEY=op://VAULT/ITEM/consumer_key
INSTAPAPER_CONSUMER_SECRET=op://VAULT/ITEM/consumer_secret
INSTAPAPER_OAUTH_TOKEN=op://VAULT/ITEM/oauth_token
INSTAPAPER_OAUTH_TOKEN_SECRET=op://VAULT/ITEM/oauth_token_secret
