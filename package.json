{
  "name": "popyson-io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerender.mjs && node scripts/build_pagefind.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit --project component",
    "test:watch": "vitest --project unit --project component",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:integration": "npm run build && vitest run --project integration",
    "coverage": "vitest run --project unit --project component --coverage",
    "metadata:generate": "node scripts/generate_metadata.mjs",
    "metadata:generate:op": "op run --env-file=.op.env -- node scripts/generate_metadata.mjs",
    "metadata:preview-prompts": "node scripts/generate_metadata.mjs --preview-prompts",
    "new:post": "node scripts/new_post.mjs",
    "lighthouse": "python3 scripts/run_lighthouse.py",
    "reading:fetch": "node scripts/fetch_instapaper.mjs",
    "reading:fetch:op": "op run --env-file=.op.env -- node scripts/fetch_instapaper.mjs",
    "instapaper:auth:op": "op run --env-file=.op.env.auth -- node scripts/instapaper_auth.mjs"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@shikijs/rehype": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "happy-dom": "^20.10.6",
    "lighthouse": "^13.4.0",
    "pagefind": "^1.5.2",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.1",
    "smol-toml": "^1.7.0",
    "typescript": "^7.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  }
}
